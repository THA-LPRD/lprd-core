{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.next",
      "!**/.turbo",
      "!**/build",
      "!**/coverage",
      "!**/dist",
      "!**/node_modules",
      "!**/convex/_generated",
      "!Example-Templates",
      "!.agents",
      "!.claude"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "bracketSpacing": true,
    "indentStyle": "space",
    "indentWidth": 4,
    "lineWidth": 120,
    "lineEnding": "lf",
    "trailingNewline": true,
    "useEditorconfig": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noStaticElementInteractions": "off",
        "noSvgWithoutTitle": "off",
        "useAriaPropsSupportedByRole": "off",
        "useFocusableInteractive": "off",
        "useKeyWithClickEvents": "off",
        "useSemanticElements": "off"
      }
    }
  },
  "css": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 120,
      "lineEnding": "lf",
      "quoteStyle": "single",
      "trailingNewline": true
    },
    "parser": {
      "tailwindDirectives": true
    }
  },
  "html": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 120,
      "lineEnding": "lf",
      "trailingNewline": true
    }
  },
  "javascript": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 4,
      "lineWidth": 120,
      "lineEnding": "lf",
      "quoteStyle": "single",
      "quoteProperties": "preserve",
      "semicolons": "always",
      "trailingCommas": "all",
      "bracketSpacing": true,
      "trailingNewline": true
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 120,
      "lineEnding": "lf",
      "bracketSpacing": true,
      "trailingCommas": "none",
      "trailingNewline": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.{json,jsonc,yml,yaml}"],
      "formatter": {
        "indentWidth": 2
      }
    }
  ]
}
