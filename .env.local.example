# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev://your-deployment-id

NEXT_PUBLIC_CONVEX_URL=https://your-deployment-id.convex.cloud

# WorkOS AuthKit Configuration
WORKOS_CLIENT_ID=client_your_client_id_here
WORKOS_API_KEY=sk_test_your_api_key_here
WORKOS_COOKIE_PASSWORD=your_secure_password_here_must_be_at_least_32_characters_long
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# WorkOS Webhook Configuration
# Path secret (random 32-char hex string for URL obscurity)
# Generate with: openssl rand -hex 8
WORKOS_WEBHOOK_USERS_PATH_SECRET=your_random_32_char_hex_string

# Webhook signature secrets (one per event type, from WorkOS dashboard)
# Set these after creating webhooks in WorkOS dashboard
WORKOS_WEBHOOK_USERS_CREATED_SECRET=wh_sec_created_secret_from_workos
WORKOS_WEBHOOK_USERS_UPDATED_SECRET=wh_sec_updated_secret_from_workos
WORKOS_WEBHOOK_USERS_DELETED_SECRET=wh_sec_deleted_secret_from_workos

# Worker Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CONVEX_URL=https://your-deployment-id.convex.cloud
CONVEX_DEPLOY_KEY=YourConvexDeploymentKey
