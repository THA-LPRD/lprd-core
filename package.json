{
  "name": "lprd-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n convex,next,worker -c blue,green,yellow \"bun run dev:convex\" \"bun run dev:web\" \"bun run worker\"",
    "dev:web": "next dev",
    "dev:convex": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "worker": "bun run src/worker/index.ts",
    "worker:build": "bun build src/worker/index.ts --outdir dist/worker --target node"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@convex-dev/workos": "^0.0.1",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@uiw/react-codemirror": "^4.25.9",
    "@workos-inc/authkit-nextjs": "^3.0.0",
    "@workos-inc/node": "^8.11.0",
    "bullmq": "^5.73.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "dompurify": "^3.3.3",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "nunjucks": "^3.2.4",
    "playwright": "^1.59.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.5.1",
    "@types/nunjucks": "^3.2.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2"
  }
