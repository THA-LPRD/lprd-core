# Convex
CONVEX_DEPLOYMENT=dev://your-deployment-id

# WorkOS AuthKit / Connect
WORKOS_CLIENT_ID=client_your_client_id_here
WORKOS_API_KEY=sk_test_your_api_key_here
WORKOS_AUTHKIT_DOMAIN=https://your-org.authkit.app

# WorkOS webhook routing secrets.
# Path secret: generate with `openssl rand -hex 32`.
WORKOS_WEBHOOK_USERS_PATH_SECRET=your_random_32_char_hex_string
WORKOS_WEBHOOK_ORGS_PATH_SECRET=your_random_32_char_hex_string

# WorkOS webhook signature secrets.
# User webhook (user.created/updated/deleted)
WORKOS_WEBHOOK_USERS_CREATED_SECRET=wh_sec_created_secret_from_workos
WORKOS_WEBHOOK_USERS_UPDATED_SECRET=wh_sec_updated_secret_from_workos
WORKOS_WEBHOOK_USERS_DELETED_SECRET=wh_sec_deleted_secret_from_workos
# Organization webhook (organization.created/updated/deleted)
WORKOS_WEBHOOK_ORGS_CREATED_SECRET=wh_sec_org_created_secret_from_workos
WORKOS_WEBHOOK_ORGS_UPDATED_SECRET=wh_sec_org_updated_secret_from_workos
WORKOS_WEBHOOK_ORGS_DELETED_SECRET=wh_sec_org_deleted_secret_from_workos
